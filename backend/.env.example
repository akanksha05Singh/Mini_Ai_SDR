# Database Connection String (PostgreSQL asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sdr

# JWT Authentication Configuration
JWT_SECRET=replace_this_with_a_long_random_secure_key_string_32_characters_plus
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Provider Access Keys
# Provide active API keys below for live scoring and email generation
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
